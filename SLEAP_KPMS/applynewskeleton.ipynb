import sleap_io as sio
import numpy as np

# === CONFIGURE ===
old_path = "old_16node_labels.slp"
clean_skeleton_path = "correct_9node_project.slp"
output_path = "rebuilt_9node_labels.slp"
# =================

# Load files
old_labels = sio.load_slp(old_path)
clean_labels = sio.load_slp(clean_skeleton_path)

old_skel = old_labels.skeletons[0]
new_skel = clean_labels.skeletons[0]

old_names = old_skel.node_names
new_names = new_skel.node_names

print("Old node count:", len(old_names))
print("New node count:", len(new_names))

# Build mapping from new node → old index
name_to_old_index = {name: i for i, name in enumerate(old_names)}

keep_indices = []
for name in new_names:
    if name not in name_to_old_index:
        raise ValueError(f"Node '{name}' not found in old skeleton.")
    keep_indices.append(name_to_old_index[name])

# Rebuild instances
for lf in old_labels:
    for inst in lf.instances:
        old_points = inst.points_array
        new_points = old_points[keep_indices]

        inst.skeleton = new_skel
        inst.points_array = new_points

    for inst in lf.predicted_instances:
        old_points = inst.points_array
        new_points = old_points[keep_indices]

        inst.skeleton = new_skel
        inst.points_array = new_points

# Replace skeleton
old_labels.skeletons = [new_skel]

# Save new file
sio.save_slp(old_labels, output_path)

print("Saved cleaned file:", output_path)
